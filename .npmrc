# --------------------------------------------------------------------------
# Shared config (read by both npm and pnpm)
# --------------------------------------------------------------------------
registry=https://registry.npmjs.org/

# --------------------------------------------------------------------------
# pnpm-only settings (npm will warn but will NOT fail on these)
# --------------------------------------------------------------------------

# Hoist all packages to the root node_modules so tools that expect a flat
# layout (VSCode TS server, Jest, etc.) work without extra configuration.
shamefully-hoist=true

# Automatically install peer dependencies declared by workspace packages.
auto-install-peers=true

# Warn — but do not abort — when a peer dependency constraint is not met.
# Prevents install from failing on minor version mismatches.
strict-peer-dependencies=false
